# ──────────────────────────────────────────────
# Chess Opening Intelligence — Environment Config
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your local paths.
# .env is git-ignored and never committed.
# ──────────────────────────────────────────────

# Path to the directory containing Lichess .zst dump files
LICHESS_DUMP_DIR=/path/to/your/zst/files

# Path to the DuckDB database file
DUCKDB_PATH=./data/chess_oi.duckdb

# Pipeline logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Chunk size for streaming PGN processing
CHUNK_SIZE=100000
